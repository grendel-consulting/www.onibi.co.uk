{
  "name": "www.onibi.co.uk",
  "description": "Brochureware site for Onibi imprint",
  "author": {
    "name": "James Ramirez"
  },
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "preinstall": "pnpm dlx only-allow pnpm",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --ignore-path .gitignore --write \"**/*.{js,mjs,json,ts,tsx,md,mdx,yml,astro,feature}\"",
    "synth": "turbo run synth",
    "browsers": "turbo run browsers",
    "e2e": "turbo run e2e",
    "ci": "turbo run ci"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead"
    ],
    "development": [
      "last 2 Chrome versions",
      "last 1 Firefox versions",
      "last 1 Safari versions"
    ]
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-gherkin": "3.1.3",
    "turbo": "2.8.15",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "sharp@<0.32.6": ">=0.32.6",
      "brace-expansion@>=1.0.0 <=1.1.11": ">=1.1.12",
      "brace-expansion@>=2.0.0 <=2.0.1": ">=2.0.2",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "@smithy/config-resolver@<4.4.0": ">=4.4.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "diff@>=4.0.0 <4.0.4": ">=4.0.4",
      "js-yaml@<3.14.2": ">=3.14.2",
      "mdast-util-to-hast@>=13.0.0 <13.2.1": ">=13.2.1",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=7.0.0 <7.4.7": ">=7.4.7",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@>=7.0.0 <7.4.8": ">=7.4.8",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@<3.1.4": ">=3.1.4",
      "fast-xml-parser@>=4.1.3 <4.5.4": ">=4.5.4",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "fast-xml-parser@>=4.0.0-beta.0 <4.5.4": ">=4.5.4",
      "svgo@=4.0.0": ">=4.0.1"
    }
  }
}
